# Copier vers .env et ajuster.

# Base locale (SQLite) — source de vérité en développement
VOIX_DB_PATH=./data/voix.db

# PostgreSQL serverless (Neon) — production ou branche de préprod.
# Si défini et non vide, l’application utilisera cette URL plutôt que SQLite
# (implémentation à brancher dans voix.db une fois le schéma Postgres stabilisé).
# Exemple : postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
VOIX_DATABASE_URL=

VOIX_CACHE_DIR=./data/cache
VOIX_USER_AGENT="Voix.qc bot — contact: ton@courriel.qc.ca"
VOIX_RATE_LIMIT_SECONDS=2
VOIX_API_HOST=127.0.0.1
VOIX_API_PORT=8080

# URL publique de l’API (pour CORS / fetch depuis le frontend déployé sur Netlify)
VOIX_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
